# ass.rest — environment variables
# Copy to .env.local for local dev, or set in Vercel Project Settings → Environment Variables

# Bearer token clients must send in `Authorization: Bearer <token>` for /api/shorten and /api/ai
ASS_REST_API_KEY=replace-me-with-the-token-i-give-you

# Upstash Redis (REST). Create at https://console.upstash.com → Create Database → pick a region near your Vercel project.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# GeneralCompute API (https://docs.generalcompute.com/)
GENERALCOMPUTE_API_KEY=gc-your-key
# Optional override; defaults to https://api.generalcompute.com/v1
# GENERALCOMPUTE_BASE_URL=https://api.generalcompute.com/v1
